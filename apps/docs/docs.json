{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Notra Documentation",
  "description": "Documentation for Notra, the content pipeline for teams.",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#8b5cf6",
    "dark": "#8b5cf6"
  },
  "background": {
    "decoration": "windows"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/overview"
    },
    {
      "source": "/api",
      "destination": "/api/getting-started"
    }
  ],
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "perplexity",
      {
        "title": "Open in T3 Chat",
        "description": "Ask questions about this page",
        "icon": "https://t3.chat/favicon.ico",
        "href": {
          "base": "https://t3.chat/new",
          "query": [
            {
              "key": "q",
              "value": "Read from https://docs.usenotra.com/$path so I can ask questions about it."
            }
          ]
        }
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          {
            "group": "Getting Started",
            "pages": ["overview"]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/github", "integrations/featul"]
          }
        ],
        "root": "overview"
      },
      {
        "tab": "API",
        "pages": [
          "api/getting-started",
          "api/authentication",
          "api/pagination",
          "api/types",
          {
            "group": "Routes",
            "expanded": true,
            "openapi": {
              "source": "openapi.json",
              "directory": "api-reference"
            },
            "pages": [
              "GET /v1/{organizationId}/posts",
              "GET /v1/{organizationId}/posts/{postId}"
            ]
          }
        ],
        "root": "api/getting-started"
      },
      {
        "tab": "SDK",
        "pages": [
          "sdk/getting-started",
          {
            "group": "Methods",
            "expanded": true,
            "openapi": {
              "source": "https://spec.speakeasy.com/notra/notra/notra-api-with-code-samples",
              "directory": "sdk-reference"
            },
            "pages": [
              "GET /v1/{organizationId}/posts",
              "GET /v1/{organizationId}/posts/{postId}"
            ]
          }
        ],
        "root": "sdk/getting-started"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord Community",
          "href": "https://www.usenotra.com/discord",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "favicon.svg",
    "dark": "favicon.svg"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usenotra",
      "github": "https://github.com/usenotra"
    }
  }
}
